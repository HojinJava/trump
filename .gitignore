# 모든 파일 무시
*

# 허용 목록만 추적
!.gitignore
!README.md
!CLAUDE.md

# 이벤트 유형별 파이프라인 지침서
!docs/
!docs/CLAUDE-*.md
!index.json
!index.html
!main.js
!style.css

# data/{id}/event.json 허용
!data/
!data/*/
!data/*/event.json

# 티커 설정 (REST /tickers 역할)
!tickers.json

# DB 마이그레이션용 스키마 메타정보
!schema/
!schema/*.json
