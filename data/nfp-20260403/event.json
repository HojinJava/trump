  "title": "NFP April 2026: Actual +178K / Forecast +65K",
  "title_ko": "3월 미국 고용보고서 (NFP +178K, 예상 대폭 상회)",
  "category": "employment",
  "broadcast_at": "2026-04-03T21:30:00+09:00",
  "duration_seconds": 0,
  "transcript": "NFP: +178K (Forecast: +65K)\nPrevious: +151K (Jan revised +34K, Feb revised -41K)\nSurprise: +113K (+173.8%)\nUnemployment Rate: 4.3%\nAvg Hourly Earnings: +0.2% MoM / +3.5% YoY\nKey sectors: Healthcare +76K, Construction, Transportation & Warehousing",
  "indices": {
    "rage": 0,
    "primary_target": null,
    "targets": [],
    "trade_war": 0,
    "chaos": 0,
    "market_brag": 0,
    "trump_risk_score": 0,
